# setlist.fm - register a free API key (non-commercial use):
# https://api.setlist.fm/docs/1.0/index.html
NUXT_SETLISTFM_API_KEY=

# Spotify app - https://developer.spotify.com/dashboard
# Register these redirect URIs on the app (Spotify requires HTTPS, and only
# allows http on the 127.0.0.1 loopback, never localhost):
#   http://127.0.0.1:3000/auth/spotify
#   https://YOUR_DOMAIN/auth/spotify
NUXT_OAUTH_SPOTIFY_CLIENT_ID=
NUXT_OAUTH_SPOTIFY_CLIENT_SECRET=

# Seals the session cookie. Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Public site URL, used for canonical + Open Graph tags. Locally, browse the
# app at http://127.0.0.1:3000 (not localhost) so the Spotify redirect matches.
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
